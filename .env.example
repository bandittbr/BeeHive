# =============================================================================
# BeeHive — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
#   cp .env.example .env
#
# ⚠ NUNCA commite o .env real — ele está no .gitignore.
# No Railway, configure estas variáveis no dashboard (service > Variables).
# =============================================================================

# --- Provedor de IA ---
# Escolha: 'ollama' (local) ou 'openai' (cloud)
AI_PROVIDER=openai

# --- OpenRouter (cloud, gratuito) ---
# Crie sua chave em: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-aqui-sua-chave
OPENAI_MODEL=meta-llama/llama-3.1-8b-instruct
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_PROVIDER_NAME=openrouter

# Alternativa: OpenAI (pago)
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_PROVIDER_NAME=openai

# Alternativa: Groq (gratuito)
# OPENAI_API_KEY=gsk_...
# OPENAI_MODEL=llama3-70b-8192
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_PROVIDER_NAME=groq

# --- Servidor ---
PORT=4000
