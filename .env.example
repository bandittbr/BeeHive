# =============================================================================
# BeeHive — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
#   cp .env.example .env
# =============================================================================

# --- Inteligência (obrigatório) ---
# Modelo Ollama padrão (deve estar disponível localmente)
OLLAMA_MODEL=llama3.2

# URL base do Ollama (padrão: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# --- CrewAI (opcional, apenas para testes com agendamento) ---
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# --- Servidor (opcional) ---
# Porta do servidor Express (padrão: 3001)
PORT=3001
