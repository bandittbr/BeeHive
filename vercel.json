{
  "buildCommand": "npm install && npx prisma generate && cd apps/control-center && npm run build",
  "outputDirectory": "apps/control-center/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "installCommand": "npm install"
}
