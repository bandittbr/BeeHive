# Configuração do backend do BeeHive (copie para .env e ajuste se necessário)

# Porta do servidor da API
PORT=4000

# Endereço do Ollama local (padrão da instalação do Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Modelo a ser usado. Lembre de baixá-lo antes: `ollama pull llama3.2`
OLLAMA_MODEL=llama3.2
