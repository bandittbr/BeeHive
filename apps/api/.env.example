# =============================================================================
# BeeHive API — Variáveis de Ambiente
# =============================================================================
# Copie para .env e ajuste. NUNCA commite o .env (está no .gitignore).
# No Railway, configure no dashboard (service > Variables).
# =============================================================================

# Porta do servidor
PORT=4000

# ============================================
# MODO OMNIROUTE (recomendado para produção)
# ============================================
# Gateway OmniRoute (https://github.com/diegosouzapw/OmniRoute) deployado
# como serviço próprio (Railway). Ele mesmo faz fallback entre 177 provedores
# (Groq, OpenRouter, Gemini, etc.) — o BeeHive só fala com UM endpoint.
# Ver docs/integrations/omniroute.md para o passo a passo de deploy.
# ============================================
AI_PROVIDER=openai
# URL pública do serviço OmniRoute no Railway (sem barra no final):
OMNIROUTE_URL=https://SEU-OMNIROUTE.up.railway.app
# Chave gerada no Dashboard do OmniRoute (Endpoints → API Key):
OPENAI_API_KEY=
OPENAI_MODEL=auto

# ============================================
# MODO LLM ROUTER (alternativa: BeeHive gerencia o failover sozinho, sem OmniRoute)
# ============================================
# Usa múltiplos providers free com failover automático.
# Basta configurar pelo menos uma chave abaixo.
# Descomente AI_PROVIDER=llmrouter acima (e comente o bloco OMNIROUTE) pra usar este modo.
# ============================================
# AI_PROVIDER=llmrouter

# --- Groq (prioridade 1: mais rápido, free tier generoso) ---
# Crie sua chave em: https://console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=llama3-70b-8192
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- OpenRouter (prioridade 2: muitos modelos free) ---
# Crie sua chave em: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-aqui-sua-chave
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- OpenAI (prioridade 3: fallback pago, opcional) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# MODO SIMPLES (apenas um provedor)
# ============================================
# Alternativa: use AI_PROVIDER=openai com apenas uma chave:
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_PROVIDER_NAME=openai

# ============================================
# MODO LOCAL (Ollama)
# ============================================
# Alternativa: use AI_PROVIDER=ollama
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
