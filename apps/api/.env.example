# BeeHive API - Environment Variables
# Copy to .env and fill in your values

# Server
PORT=4000
AI_PROVIDER=openai  # options: openai | llmrouter | ollama

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI / OpenAI-compatible (OpenRouter, OmniRoute, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_PROVIDER_NAME=openai

# OpenRouter (free models with fallback)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Groq (fast, generous free tier)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama3-70b-8192

# OpenCode Zen (free, includes big-pickle model)
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=big-pickle

# Kiro (AWS Bedrock Claude via local gateway)
KIRO_API_KEY=
KIRO_BASE_URL=http://localhost:8000/v1
KIRO_MODEL=claude-sonnet-4-20250514

# Optional: OmniRoute gateway URL (auto-configures OPENAI_BASE_URL if set)
OMNIROUTE_URL=

# Database
DATABASE_PATH=data/beehive.db

# Redis (for BullMQ worker - affiliates)
REDIS_URL=