{
  "providers": {
    "ai": {
      "default": "mock",
      "available": ["mock", "openrouter", "ollama", "gemini", "openai", "anthropic"],
      "chat.generate": {
        "provider": "mock",
        "model": "meta-llama/llama-3-8b-instruct:free"
      },
      "memory.search": {
        "provider": "mock"
      },
      "tool.execute": {
        "provider": "mock"
      }
    },
    "browser": {
      "default": "playwright",
      "browser.navigate": {
        "provider": "playwright"
      },
      "browser.scrape": {
        "provider": "playwright"
      },
      "browser.screenshot": {
        "provider": "playwright"
      }
    }
  }
}
