{
  "name": "@beehive/platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BeeHive — plataforma compartilhada (Kernel, Module System, Service Layer, AI Layer, Tool System, Runtime). Agnóstica de ambiente: roda em apps/api (Node) e é consumida por apps/web só por tipos/contratos.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts",
    "./runtime": "./src/runtime/index.ts",
    "./browser": "./src/browser/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "tsx --test src/ai/providers/ollama/OllamaProvider.test.ts src/ai/ProviderManager.test.ts src/ai/AIManager.test.ts src/modules/conversation/ConversationMemory.test.ts src/modules/conversation/ConversationService.test.ts src/tools/filesystem/FilesystemTool.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "playwright": "^1.47.0",
    "playwright-stealth": "^0.0.1"
  }
}
