{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm run start --workspace apps/api",
    "healthcheckPath": "/api/runtime/status",
    "restartPolicyType": "on-failure",
    "restartPolicyMaxRetries": 5
  }
}
