{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "pnpm --filter @beehive/api run build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "pnpm --filter apps/api run start",
    "healthcheckPath": "/api/runtime/status"
  }
}
